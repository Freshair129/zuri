  note        String?

  po PurchaseOrderV2 @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@unique([poId, productId, productType])
  @@map("po_items")
}

model POApproval {
  id         String   @id @default(uuid())
  poId       String   @map("po_id")
  tenantId   String   @map("tenant_id")
  approverId String   @map("approver_id")
  action     String
  note       String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  po PurchaseOrderV2 @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([poId])
  @@index([tenantId])
  @@map("po_approvals")
}

model POAcceptance {
  id         String   @id @default(uuid())
  poId       String   @unique @map("po_id")
  tenantId   String   @map("tenant_id")
  acceptedAt DateTime @map("accepted_at")
  acceptedBy String   @map("accepted_by")
  note       String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("po_acceptances")
}

model POTracking {
  id               String    @id @default(uuid())
  poId             String    @map("po_id")
  tenantId         String    @map("tenant_id")
  carrier          String?
  trackingNumber   String?   @map("tracking_number")
  estimatedArrival DateTime? @map("estimated_arrival")
  status           String    @default("IN_TRANSIT")
  note             String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  po PurchaseOrderV2 @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("po_tracking")
}

model GoodsReceivedNote {
  id           String   @id @default(uuid())
  grnId        String   @unique @map("grn_id")
  tenantId     String   @map("tenant_id")
  poId         String   @map("po_id")
  warehouseId  String   @map("warehouse_id")
  receivedById String   @map("received_by_id")
  receivedAt   DateTime @default(now()) @map("received_at")
  note         String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  items GRNItem[]
  po    PurchaseOrderV2 @relation(fields: [poId], references: [id])

  @@index([tenantId])
  @@index([poId])
  @@map("goods_received_notes")
}

model GRNItem {
  id          String    @id @default(uuid())
  grnId       String    @map("grn_id")
  productId   String    @map("product_id")
  productType String    @map("product_type")
  qtyReceived Float     @map("qty_received")
  unitCost    Float     @map("unit_cost")
  batchNumber String?   @map("batch_number")
  expiresAt   DateTime? @map("expires_at")
  note        String?

  grn GoodsReceivedNote @relation(fields: [grnId], references: [id], onDelete: Cascade)

  @@unique([grnId, productId])
  @@map("grn_items")
}

model POReturn {
  id        String   @id @default(uuid())
  returnId  String   @unique @map("return_id")
  tenantId  String   @map("tenant_id")
  poId      String   @map("po_id")
  grnId     String?  @map("grn_id")
  reason    String   @db.Text
  items     Json     @default("[]")
  status    String   @default("PENDING")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([poId])
  @@map("po_returns")
}

model POIssue {
  id           String    @id @default(uuid())
  issueId      String    @unique @map("issue_id")
  tenantId     String    @map("tenant_id")
  poId         String    @map("po_id")
  issueType    String    @map("issue_type")
  description  String    @db.Text
  resolvedAt   DateTime? @map("resolved_at")
  resolvedById String?   @map("resolved_by_id")
  status       String    @default("OPEN")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([poId])
  @@map("po_issues")
}

// ============================================
// DOMAIN: AI Agent Mode (M4-A2)
// ============================================

// Style profile extracted from each employee's conversation history
model AgentStyle {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  employeeId      String   @map("employee_id") // Employee.id (not employeeId string)
  tone            String   @default("casual") // formal | casual | friendly
  sentenceLength  String   @default("medium") // short | medium | long
  emojiUsage      String   @default("moderate") // none | moderate | frequent
  vocabulary      Json     @default("[]") // Array of characteristic phrases/words
  closingPatterns Json     @default("[]") // Array of sign-off patterns (e.g. ขอบคุณครับ)
  sampleMessages  Json     @default("[]") // Sample analyzed messages for reference
  analyzedAt      DateTime @default(now()) @map("analyzed_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, employeeId])
  @@index([tenantId])
  @@map("agent_styles")
}

// Audit trail for every AI-generated reply in Agent Mode
model ConversationLog {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  conversationId String   @map("conversation_id") // Conversation.id
  sender         String // 'AI' | 'HUMAN'
  content        String   @db.Text
  metadata       Json     @default("{}")
  // metadata keys: agentStyleId, escalationReason, promptTokens, modelVersion
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([tenantId, conversationId])
  @@map("conversation_logs")
}

// ============================================
// DOMAIN: Accounting Platform (FEAT17, ZDEV-TSK-20260410-016)
// ============================================

// Per-tenant, per-provider integration config + encrypted OAuth tokens
model IntegrationConfig {
  id                   String    @id @default(uuid())
  tenantId             String    @map("tenant_id")
  provider             String // flowaccount | express | peak | sage
  oauthAccessTokenEnc  String?   @map("oauth_access_token_enc") @db.Text
  oauthRefreshTokenEnc String?   @map("oauth_refresh_token_enc") @db.Text
  oauthExpiresAt       DateTime? @map("oauth_expires_at")
  accountantEmail      String?   @map("accountant_email")
  syncMode             String    @default("manual") @map("sync_mode") // manual | daily | realtime
  syncOptionsJson      Json      @default("{}") @map("sync_options_json")
  accountMappingJson   Json      @default("{}") @map("account_mapping_json")
  isActive             Boolean   @default(false) @map("is_active")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, provider], name: "tenantId_provider")
  @@index([tenantId])
  @@index([isActive])
  @@map("integration_configs")
}

// Audit trail per sync run (FlowAccount batch, Express export, etc.)
model IntegrationSyncLog {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  provider         String // flowaccount | express
  syncType         String   @map("sync_type") // invoice | contact | expense
  triggeredBy      String   @map("triggered_by") // cron | manual | realtime
  total            Int      @default(0)
  success          Int      @default(0)
  failed           Int      @default(0)
  errorDetailsJson Json?    @map("error_details_json")
  startedAt        DateTime @map("started_at")
  finishedAt       DateTime @default(now()) @map("finished_at")

  @@index([tenantId])
  @@index([provider])
  @@index([startedAt])
  @@map("integration_sync_logs")
}

// Document reference: maps Zuri entity → external accounting document
// Used for idempotency (ZRI-{orderId} dedup)
model IntegrationDocumentRef {
  id                 String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  provider           String // flowaccount | express
  zuriEntityType     String   @map("zuri_entity_type") // order | customer | expense
  zuriEntityId       String   @map("zuri_entity_id") // internal UUID
  externalDocumentId String?  @map("external_document_id")
  status             String   @default("synced") // synced | exported | failed | skipped
  syncedAt           DateTime @default(now()) @map("synced_at")

  @@unique([tenantId, provider, zuriEntityType, zuriEntityId], name: "tenantId_provider_zuriEntityType_zuriEntityId")
  @@index([tenantId])
  @@index([provider])
  @@map("integration_document_refs")
}

// ============================================
// DOMAIN: Migration Tracking (ZDEV-TSK-20260410-032)
// ============================================

// Tracks records created by scripts/migrate-zuri-v1.js so that
// scripts/migrate-rollback.js can safely delete ONLY migration-seeded
// rows without touching manually-entered data.
//
// A single migration run shares one `migrationId` (default: run timestamp)
// so rollback can target a specific run via `--migration-id=<id>`.

// ============================================
// DOMAIN: Team Invitation & Ownership (FEAT21)
// ============================================

model InvitationToken {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  token       String    @unique
  email       String
  role        String    @default("STAFF")
  invitedById String    @map("invited_by_id")
  usedAt      DateTime? @map("used_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([token])
  @@map("invitation_tokens")
}

model OwnershipTransferRequest {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  fromEmployeeId String    @map("from_employee_id")
  toEmployeeId   String    @map("to_employee_id")
  otpHash        String    @map("otp_hash")
  status         String    @default("PENDING") // PENDING | CONFIRMED | CANCELLED | EXPIRED
  expiresAt      DateTime  @map("expires_at")
  confirmedAt    DateTime? @map("confirmed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("ownership_transfer_requests")
}

model SystemAuditLog {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  type      String   // OWNERSHIP_TRANSFER | ROLE_CHANGE | MEMBER_INVITE | MEMBER_JOIN
  actorId   String   @map("actor_id")
  targetId  String?  @map("target_id")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([type])
  @@map("system_audit_logs")
}

model MigrationLog {
  id          String   @id @default(uuid())
  migrationId String   @map("migration_id") // e.g. "zuri-v1-2026-04-10T03-00-00"
  entityType  String   @map("entity_type") // employee | customer | product | order | enrollment | conversation | message
  entityId    String   @map("entity_id") // Zuri-side id (UUID) of the created row
  sourceId    String?  @map("source_id") // original id in the legacy DB (for audit / cross-reference)
  tenantId    String   @map("tenant_id") // target tenant (usually V School)
  migratedAt  DateTime @default(now()) @map("migrated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([migrationId, entityType, entityId], name: "migrationId_entityType_entityId")
  @@index([tenantId])
  @@index([migrationId])
  @@index([entityType])
  @@index([migratedAt])
  @@map("migration_logs")
}
