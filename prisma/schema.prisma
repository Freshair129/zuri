// ============================================
// DOMAIN: Audit
// ============================================

// Audit log — append-only trail of sensitive actions (ZDEV-TSK-20260410-026)
//
// IMMUTABILITY: this table is conceptually append-only. The auditRepo
// intentionally exposes only `create` and `find*` — no update or delete.
// A future hardening pass can add a Postgres trigger blocking UPDATE/DELETE,
// but the application contract is the first line of defense.
model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?  @map("tenant_id")
  actor      String // legacy: free-form string ("EMP-123" or "system")
  actorId    String?  @map("actor_id") // canonical Employee.id when known
  actorRole  String?  @map("actor_role") // normalized role at the time of the action
  action     String // e.g. UPDATE_EMPLOYEE_ROLE, EXPORT_REVENUE
  target     String? // resource id (e.g. customer-uuid, order-uuid)
  targetType String?  @map("target_type") // resource type (customer, order, employee, integration)
  before     Json? // snapshot of fields BEFORE the change
  after      Json? // snapshot of fields AFTER the change
  details    Json? // free-form metadata for the action
  ipAddress  String?  @map("ip_address") // x-forwarded-for / x-real-ip
  userAgent  String?  @map("user_agent") @db.Text // request UA header
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([actor])
  @@index([actorId])
  @@index([action])
  @@index([target])
  @@index([createdAt])
  @@map("audit_logs")
}

