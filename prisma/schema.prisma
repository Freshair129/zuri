generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// Multi-Tenant Foundation (ADR-056)
// ============================================

model Tenant {
  id                String   @id @default(uuid())
  tenantSlug        String   @unique @map("tenant_slug")
  tenantName        String   @map("tenant_name")
  lineOaId          String?  @map("line_oa_id")
  fbPageId          String?  @map("fb_page_id")
  fbPageToken       String?  @map("fb_page_token") // AES-256-CBC encrypted
  lineChannelToken  String?  @map("line_channel_token") // AES-256-CBC encrypted
  lineChannelSecret String?  @map("line_channel_secret") // AES-256-CBC encrypted
  plan              String   @default("STARTER")
  isActive          Boolean  @default(true) @map("is_active")
  // Per-tenant branding & config (FEAT01 MT-P4): vatRate, currency, timezone, brandColor, logoUrl
  config            Json     @default("{}") @map("config")
  ownerEmployeeId   String?  @map("owner_employee_id") // FEAT21: current OWNER employee id
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  employees          Employee[]
  customers          Customer[]
  conversations      Conversation[]
  orders             Order[]
  tasks              Task[]
  adAccounts         AdAccount[] // ZDEV-TSK-20260409-053
  integrationConfigs IntegrationConfig[] // FEAT17 Accounting Platform
  marketingConfig    TenantMarketingConfig? // FEAT15 Marketing AI

  @@map("tenants")
}

// ============================================
// DOMAIN: Auth & Employee
// ============================================

model Employee {
  id           String    @id @default(uuid())
  employeeId   String    @unique @map("employee_id")
  tenantId     String    @map("tenant_id")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  nickName     String?   @map("nick_name")
  email        String    @unique
  phone        String?
  lineUserId   String?   @map("line_user_id")
  department   String?
  jobTitle     String?   @map("job_title")
  role         String    @default("STF")
  roles        String[]  @default(["STF"])
  status       String    @default("ACTIVE")
  passwordHash String    @map("password_hash")
  hiredAt      DateTime? @map("hired_at")
  lastLoginAt  DateTime? @map("last_login_at")
  lastLoginIp  String?   @map("last_login_ip") // ZDEV-TSK-20260410-025
  deviceId     String?   @map("device_id")     // ZDEV-TSK-20260410-025
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("employees")
}

// ============================================
// DOMAIN: Session Management (ZDEV-TSK-20260410-025)
// ============================================

model ActiveSession {
  id         String   @id @default(uuid())
  sessionId  String   @unique // jti in JWT
  employeeId String   @map("employee_id")
  tenantId   String   @map("tenant_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent") @db.Text
  deviceId   String?  @map("device_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([employeeId])
  @@map("active_sessions")
}


// ============================================
// DOMAIN: Customer CRM
// ============================================

model Customer {
  id             String    @id @default(uuid())
  customerId     String    @unique @map("customer_id")
  tenantId       String    @map("tenant_id")
  name           String? // display name (manual create / override)
  status         String    @default("Active")
  membershipTier String    @default("MEMBER") @map("membership_tier")
  lifecycleStage String    @default("NEW") @map("lifecycle_stage")
  tags           String[]  @default([])
  email          String?
  phonePrimary   String?   @map("phone_primary")
  phoneSecondary String?   @map("phone_secondary")
  lineId         String?   @map("line_id")
  facebookId     String?   @unique @map("facebook_id")
  facebookName   String?   @map("facebook_name")
  assigneeId     String?   @map("assignee_id") // Employee.id responsible for this customer
  originId       String?   @map("origin_id")
  mergedInto     String?   @map("merged_into") // primary customer id when this is a secondary
  walletBalance  Float     @default(0) @map("wallet_balance")
  walletPoints   Int       @default(0) @map("wallet_points")
  intentScore    Int       @default(0) @map("intent_score")
  churnScore     Int       @default(0) @map("churn_score")
  intelligence   Json?
  deletedAt      DateTime? @map("deleted_at") // soft delete
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  tenant        Tenant                 @relation(fields: [tenantId], references: [id])
  conversations Conversation[]
  orders        Order[]
  enrollments   Enrollment[]
  profile       CustomerProfile?
  insight       CustomerInsight?
  stageHistory  CustomerStageHistory[]
  activities    CustomerActivity[]

  @@index([tenantId])
  @@index([phonePrimary])
  @@index([lifecycleStage])
  @@index([deletedAt])
  @@map("customers")
}

// Tracks every lifecycle stage transition with timestamp + actor
model CustomerStageHistory {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  customerId String   @map("customer_id")
  fromStage  String?  @map("from_stage")
  toStage    String   @map("to_stage")
  changedBy  String?  @map("changed_by") // Employee.id
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@map("customer_stage_history")
}

// Unified activity timeline for a customer (conversations, orders, stage changes, notes)
model CustomerActivity {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  customerId String   @map("customer_id")
  type       String // CONVERSATION | ORDER | STAGE_CHANGE | TAG_CHANGE | NOTE | ENROLLMENT
  refId      String?  @map("ref_id") // id of the referenced entity
  payload    Json     @default("{}") // activity-specific data
  actorId    String?  @map("actor_id") // Employee.id who caused the event
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@index([type])
  @@map("customer_activities")
}

model CustomerProfile {
  id             String    @id @default(uuid())
  customerId     String    @unique @map("customer_id")
  gender         String?
  ageRange       String?   @map("age_range")
  hasChildren    Boolean?  @map("has_children")
  occupation     String?
  educationLevel String?   @map("education_level")
  location       String?
  cookingLevel   String?   @map("cooking_level")
  motivation     String[]  @default([])
  budgetSignal   String?   @map("budget_signal")
  inferenceCount Int       @default(0) @map("inference_count")
  lastInferredAt DateTime? @map("last_inferred_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

model CustomerInsight {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  customerId     String   @unique @map("customer_id")
  interests      String[] @default([])
  objections     String[] @default([])
  commStyle      String?  @map("comm_style")
  keyFacts       String[] @default([]) @map("key_facts")
  summary        String?  @db.Text
  contactPref    String?  @map("contact_pref")
  manualOverride Json?    @map("manual_override")
  enrichedAt     DateTime @default(now()) @map("enriched_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("customer_insights")
}

model TenantCRMPattern {
  id             String   @id @default(uuid())
  tenantId       String   @unique @map("tenant_id")
  topObjections  Json     @default("[]") @map("top_objections")
  topInterests   Json     @default("[]") @map("top_interests")
  conversionTips Json     @default("[]") @map("conversion_tips")
  bestAdSegments Json?    @map("best_ad_segments")
  computedAt     DateTime @default(now()) @map("computed_at")

  @@map("tenant_crm_patterns")
}

// ============================================
// DOMAIN: Inbox & Conversations
// ============================================

model Conversation {
  id             String   @id @default(uuid())
  conversationId String   @unique @map("conversation_id")
  tenantId       String   @map("tenant_id")
  customerId     String?  @map("customer_id")
  participantId  String?  @map("participant_id")
  channel        String   @default("facebook")
  firstTouchAdId String?  @map("first_touch_ad_id")
  assigneeId     String?  @map("assignee_id")
  status         String   @default("open")
  agentMode      Boolean  @default(false) @map("agent_mode") // M4-A2: AI agent auto-reply mode
  agentTurnCount Int      @default(0) @map("agent_turn_count") // M4-A2: # of consecutive AI replies
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant   Tenant                 @relation(fields: [tenantId], references: [id])
  customer Customer?              @relation(fields: [customerId], references: [id])
  messages Message[]
  analyses ConversationAnalysis[]

  @@index([tenantId])
  @@index([customerId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  messageId      String   @unique @map("message_id")
  conversationId String   @map("conversation_id")
  sender         String
  content        String?  @db.Text
  attachments    Json?
  responderId    String?  @map("responder_id")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

// ============================================
// DOMAIN: Orders & Payments
// ============================================

model Order {
  id               String    @id @default(uuid())
  orderId          String    @unique @map("order_id")
  tenantId         String    @map("tenant_id") // CRITICAL: multi-tenant isolation
  customerId       String?   @map("customer_id") // nullable — walk-in customers
  tableId          String?   @map("table_id") // PosTable.id (onsite orders)
  guestCount       Int       @default(1) @map("guest_count") // Number of customers
  extraSeats       Int       @default(0) @map("extra_seats") // Number of extra seats/stools
  isMerged         Boolean   @default(false) @map("is_merged") // Part of a merged table order
  mergeGroupId     String?   @map("merge_group_id") // ID for grouped tables
  closedById       String?   @map("closed_by_id") // Employee.id
  conversationId   String?   @map("conversation_id")
  status           String    @default("PENDING") // PENDING | PAID | VOID | REFUNDED
  orderType        String    @default("TAKEAWAY") @map("order_type") // ONSITE | TAKEAWAY | ONLINE | DELIVERY
  subtotalAmount   Float     @default(0) @map("subtotal_amount")
  discountAmount   Float     @default(0) @map("discount_amount")
  vatAmount        Float     @default(0) @map("vat_amount")
  serviceCharge    Float     @default(0) @map("service_charge")
  totalAmount      Float     @default(0) @map("total_amount")
  paidAmount       Float     @default(0) @map("paid_amount")
  paymentMethod    String?   @map("payment_method") // CASH | QR | CARD | CREDIT
  cashReceived     Float?    @map("cash_received") // for change calculation
  notes            String?   @db.Text
  date             DateTime  @default(now())
  // M4 Feature A3: AI Sales Closer — Human Gate fields (ZDEV-TSK-20260410-013)
  createdBy        String?   @map("created_by") // 'AI' | null (human-created)
  requiresApproval Boolean   @default(false) @map("requires_approval") // AI orders > ฿5,000 need OWNER review
  approvedById     String?   @map("approved_by_id") // Employee.id who approved
  approvedAt       DateTime? @map("approved_at") // Timestamp of approval
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  customer     Customer?     @relation(fields: [customerId], references: [id])
  table        PosTable?     @relation(fields: [tableId], references: [id])
  items        OrderItem[]
  transactions Transaction[]

  @@index([tenantId])
  @@index([status])
  @@index([date])
  @@index([requiresApproval])
  @@map("orders")
}

// Order line items (replaces JSON items field — normalized for reporting)
model OrderItem {
  id            String  @id @default(uuid())
  orderId       String  @map("order_id")
  tenantId      String  @map("tenant_id")
  productId     String? @map("product_id") // Product.id — null for custom items
  name          String // snapshot of product name at time of sale
  qty           Int     @default(1)
  unitPrice     Float   @map("unit_price")
  discount      Float   @default(0)
  totalPrice    Float   @map("total_price")
  note          String?
  kitchenStatus String  @default("PENDING") @map("kitchen_status") // PENDING | SENT | DONE

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

model Transaction {
  id            String   @id @default(uuid())
  transactionId String   @unique @map("transaction_id")
  tenantId      String   @map("tenant_id")
  orderId       String   @map("order_id")
  amount        Float
  type          String   @default("PAYMENT") // PAYMENT | REFUND | VOID
  method        String   @default("CASH")
  slipStatus    String   @default("PENDING") @map("slip_status")
  slipData      Json?    @map("slip_data")
  slipUrl       String?  @map("slip_url")
  refNumber     String?  @unique @map("ref_number")
  date          DateTime @default(now())
  createdAt     DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@map("transactions")
}

// POS floor plan
model PosZone {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  name     String
  floor    Int    @default(1)
  color    String @default("#f97316")

  tables PosTable[]

  @@index([tenantId])
  @@map("pos_zones")
}

model PosTable {
  id        String  @id @default(uuid())
  tenantId  String  @map("tenant_id")
  zoneId    String? @map("zone_id")
  name      String
  capacity  Int     @default(4)
  shape     String  @default("rect") // rect | circle
  positionX Float   @default(0) @map("position_x")
  positionY Float   @default(0) @map("position_y")
  floor     Int     @default(1)
  status    String  @default("AVAILABLE") // AVAILABLE | OCCUPIED | RESERVED | BILL_REQUESTED | CLEANING
  isExtra   Boolean @default(false) @map("is_extra") // Is this an extra/temporary table?
  parentId  String? @map("parent_id") // For merged tables, points to the main table

  zone   PosZone? @relation(fields: [zoneId], references: [id])
  orders Order[]

  @@index([tenantId])
  @@map("pos_tables")
}

// Per-tenant receipt/document configuration
model PosReceiptConfig {
  id                String  @id @default(uuid())
  tenantId          String  @unique @map("tenant_id")
  businessName      String? @map("business_name")
  address           String? @db.Text
  taxId             String? @map("tax_id") // 13-digit Thai TIN
  phone             String?
  website           String?
  logoUrl           String? @map("logo_url")
  vatIncluded       Boolean @default(true) @map("vat_included")
  vatRate           Float   @default(7) @map("vat_rate")
  serviceChargeRate Float   @default(0) @map("service_charge_rate")
  footerText        String? @map("footer_text")

  @@map("pos_receipt_configs")
}

// ============================================
// DOMAIN: Products & Catalog
// ============================================

model Product {
  id                  String   @id @default(uuid())
  sku                 String   @unique @map("product_id") // business key (was productId) — ERP standard per ADR-075
  tenantId            String   @map("tenant_id") // CRITICAL: multi-tenant
  name                String
  description         String?  @db.Text
  category            String
  fallbackSubCategory String?  @map("fallback_sub_category")
  imageUrl            String?  @map("image_url")
  barcode             String?  @map("sku") // scannable code for POS (was sku) — ADR-075
  basePrice           Float    @default(0) @map("base_price")
  posPrice            Float?   @map("pos_price") // override base_price for POS
  hours               Float?
  sessionType         String?  @map("session_type")
  isActive            Boolean  @default(true) @map("is_active")
  isPosVisible        Boolean  @default(true) @map("is_pos_visible")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  enrollments Enrollment[]
  schedules   CourseSchedule[]
  recipes     ProductRecipe[]

  @@index([tenantId])
  @@index([category])
  @@map("products")
}

// ============================================
// DOMAIN: Enrollment & Schedule
// ============================================

model Enrollment {
  id             String    @id @default(uuid())
  enrollmentId   String    @unique @map("enrollment_id")
  tenantId       String    @map("tenant_id")
  customerId     String    @map("customer_id")
  productId      String    @map("product_id")
  packageId      String?   @map("package_id")
  orderId        String?   @map("order_id")
  soldById       String?   @map("sold_by_id")
  totalPrice     Float     @default(0) @map("total_price")
  // Lifecycle: PENDING → CONFIRMED → IN_PROGRESS → COMPLETED | CANCELLED
  status         String    @default("PENDING")
  hoursCompleted Float     @default(0) @map("hours_completed")
  enrolledAt     DateTime  @default(now()) @map("enrolled_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  customer    Customer          @relation(fields: [customerId], references: [id])
  product     Product           @relation(fields: [productId], references: [id])
  items       EnrollmentItem[]
  attendance  ClassAttendance[]
  certificate Certificate?

  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@map("enrollments")
}

// Tracks per-course progress within an Enrollment
model EnrollmentItem {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  enrollmentId   String   @map("enrollment_id")
  productId      String   @map("product_id")
  hoursCompleted Float    @default(0) @map("hours_completed")
  // PENDING | IN_PROGRESS | COMPLETED
  status         String   @default("PENDING")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@index([tenantId])
  @@map("enrollment_items")
}

// Per-class attendance record (QR check-in or staff manual mark)
model ClassAttendance {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  enrollmentId String    @map("enrollment_id")
  scheduleId   String    @map("schedule_id")
  // PRESENT | ABSENT | LATE | EXCUSED
  status       String    @default("ABSENT")
  checkedAt    DateTime? @map("checked_at")
  note         String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  enrollment Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  schedule   CourseSchedule @relation(fields: [scheduleId], references: [id])

  // prevent duplicate check-in for same student+class
  @@unique([enrollmentId, scheduleId])
  @@index([tenantId])
  @@index([scheduleId])
  @@map("class_attendances")
}

// Issued when student reaches hoursCompleted >= threshold
// format: CERT-{YYYYMMDD}-{seq} — see id_standards.yaml
model Certificate {
  id            String    @id @default(uuid())
  certificateId String    @unique @map("certificate_id")
  tenantId      String    @map("tenant_id")
  enrollmentId  String    @unique @map("enrollment_id")
  customerId    String    @map("customer_id")
  // BASIC_30H | PRO_111H | MASTER_201H
  level         String
  issuedDate    DateTime  @default(now()) @map("issued_date")
  pdfUrl        String?   @map("pdf_url")
  notifiedAt    DateTime? @map("notified_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])

  @@index([tenantId])
  @@index([customerId])
  @@map("certificates")
}

model CourseSchedule {
  id                String   @id @default(uuid())
  scheduleId        String   @unique @map("schedule_id")
  tenantId          String   @default("10000000-0000-0000-0000-000000000001") @map("tenant_id")
  productId         String   @map("product_id")
  instructorId      String?  @map("instructor_id")
  scheduledDate     DateTime @map("scheduled_date")
  startTime         String   @map("start_time")
  endTime           String   @map("end_time")
  maxStudents       Int      @default(10) @map("max_students")
  confirmedStudents Int      @default(0) @map("confirmed_students")
  status            String   @default("SCHEDULED")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  product     Product           @relation(fields: [productId], references: [id])
  attendances ClassAttendance[]

  @@index([tenantId])
  @@index([scheduledDate])
  @@map("course_schedules")
}

// ============================================
// DOMAIN: Marketing & Ads (synced from Meta via QStash)
// ZDEV-TSK-20260409-053 — added AdAccount, Campaign, AdSet,
//   AdDailyPlacement, AdHourlyMetric; added reach to AdDailyMetric
// ============================================

// AdAccount — เชื่อม Tenant กับ Meta Ad Account (1 tenant : many accounts)
model AdAccount {
  id        String   @id @default(uuid())
  accountId String   @unique @map("account_id") // Meta account_id (numeric string)
  tenantId  String   @map("tenant_id")
  name      String   @default("")
  currency  String   @default("THB")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  campaigns Campaign[]

  @@index([tenantId])
  @@map("ad_accounts")
}

// Campaign — Meta Campaign (1 AdAccount : many Campaigns)
model Campaign {
  id          String    @id @default(uuid())
  campaignId  String    @unique @map("campaign_id") // Meta campaign_id
  adAccountId String    @map("ad_account_id")
  name        String
  objective   String?
  status      String    @default("ACTIVE")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  adAccount AdAccount @relation(fields: [adAccountId], references: [accountId])
  adSets    AdSet[]

  @@index([adAccountId])
  @@map("campaigns")
}

// AdSet — Meta Ad Set (1 Campaign : many AdSets)
model AdSet {
  id          String   @id @default(uuid())
  adSetId     String   @unique @map("ad_set_id") // Meta adset_id
  campaignId  String   @map("campaign_id")
  name        String
  status      String   @default("ACTIVE")
  dailyBudget Float    @default(0) @map("daily_budget")
  targeting   Json     @default("{}") // ZDEV-TSK-20260409-054
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [campaignId])
  ads      Ad[]

  @@index([campaignId])
  @@map("ad_sets")
}

// Ad — Meta Ad (1 AdSet : many Ads)
model Ad {
  id             String   @id @default(uuid())
  adId           String   @unique @map("ad_id") // Meta ad_id
  adSetId        String?  @map("ad_set_id")
  name           String
